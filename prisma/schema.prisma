generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["nativeDistinct", "relationJoins"]
  engineType      = "client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["gebrauchtwagen"]
}

/// This schema is intentionally empty as the neutral starting point for the
/// upcoming Gebrauchtwagen aggregate. The domain models will be introduced
/// from the PostgreSQL schema via `prisma db pull`.
