diff --git a/extras/compose/postgres/init/gebrauchtwagen/sql/create-schema.sql b/extras/compose/postgres/init/gebrauchtwagen/sql/create-schema.sql
new file mode 100644
index 0000000..4784cec
--- /dev/null
+++ b/extras/compose/postgres/init/gebrauchtwagen/sql/create-schema.sql
@@ -0,0 +1,96 @@
+-- Aufruf: psql --dbname=gebrauchtwagen --username=gebrauchtwagen --file=/init/gebrauchtwagen/sql/create-schema.sql
+
+CREATE SCHEMA IF NOT EXISTS AUTHORIZATION gebrauchtwagen;
+
+ALTER ROLE gebrauchtwagen SET search_path = 'gebrauchtwagen';
+
+DO $$
+BEGIN
+    CREATE TYPE gebrauchtwagen.kraftstoffart AS ENUM (
+        'BENZIN',
+        'DIESEL',
+        'ELEKTRO',
+        'HYBRID',
+        'ERDGAS',
+        'WASSERSTOFF'
+    );
+EXCEPTION
+    WHEN duplicate_object THEN NULL;
+END
+$$;
+
+DO $$
+BEGIN
+    CREATE TYPE gebrauchtwagen.fahrzeugklasse AS ENUM (
+        'KLEINWAGEN',
+        'KOMPAKTKLASSE',
+        'MITTELKLASSE',
+        'OBERKLASSE',
+        'SUV',
+        'KOMBI',
+        'CABRIO',
+        'TRANSPORTER'
+    );
+EXCEPTION
+    WHEN duplicate_object THEN NULL;
+END
+$$;
+
+DO $$
+BEGIN
+    CREATE TYPE gebrauchtwagen.hu_status AS ENUM (
+        'BESTANDEN',
+        'NICHT_BESTANDEN',
+        'AUSSTEHEND'
+    );
+EXCEPTION
+    WHEN duplicate_object THEN NULL;
+END
+$$;
+
+CREATE TABLE IF NOT EXISTS gebrauchtwagen.gebrauchtwagen (
+    id integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
+    version integer NOT NULL DEFAULT 1,
+    fin varchar(17) NOT NULL UNIQUE,
+    marke varchar(100) NOT NULL,
+    modell varchar(100) NOT NULL,
+    baujahr integer NOT NULL,
+    erstzulassung date NOT NULL,
+    kilometerstand integer NOT NULL,
+    kraftstoffart gebrauchtwagen.kraftstoffart NOT NULL,
+    fahrzeugklasse gebrauchtwagen.fahrzeugklasse NOT NULL,
+    ausstattung jsonb NOT NULL DEFAULT '{}'::jsonb,
+    schadenfrei boolean NOT NULL,
+    beschreibung_url varchar(255),
+    anbieter_username varchar(100),
+    kontakt_email varchar(255),
+    erzeugt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
+    aktualisiert timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP
+);
+
+CREATE TABLE IF NOT EXISTS gebrauchtwagen.standort (
+    id integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
+    plz varchar(10) NOT NULL,
+    ort varchar(100) NOT NULL,
+    gebrauchtwagen_id integer NOT NULL UNIQUE
+        REFERENCES gebrauchtwagen.gebrauchtwagen(id) ON DELETE CASCADE
+);
+
+CREATE TABLE IF NOT EXISTS gebrauchtwagen.schaden (
+    id integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
+    bezeichnung varchar(100) NOT NULL,
+    beschreibung varchar(500) NOT NULL,
+    feststellungsdatum date NOT NULL,
+    gebrauchtwagen_id integer NOT NULL
+        REFERENCES gebrauchtwagen.gebrauchtwagen(id) ON DELETE CASCADE
+);
+
+CREATE TABLE IF NOT EXISTS gebrauchtwagen.hauptuntersuchung (
+    id integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
+    pruefdatum date NOT NULL,
+    gueltig_bis date NOT NULL,
+    prueforganisation varchar(100) NOT NULL,
+    status gebrauchtwagen.hu_status NOT NULL,
+    gebrauchtwagen_id integer NOT NULL UNIQUE
+        REFERENCES gebrauchtwagen.gebrauchtwagen(id) ON DELETE CASCADE
+);
diff --git a/extras/compose/postgres/init/gebrauchtwagen/sql/load-csv.sql b/extras/compose/postgres/init/gebrauchtwagen/sql/load-csv.sql
new file mode 100644
index 0000000..0e4b54e
--- /dev/null
+++ b/extras/compose/postgres/init/gebrauchtwagen/sql/load-csv.sql
@@ -0,0 +1,79 @@
+-- Aufruf: psql --dbname=gebrauchtwagen --username=gebrauchtwagen --file=/init/gebrauchtwagen/sql/load-csv.sql
+
+SET search_path TO gebrauchtwagen;
+
+TRUNCATE hauptuntersuchung, schaden, standort, gebrauchtwagen
+    RESTART IDENTITY CASCADE;
+
+COPY gebrauchtwagen (
+    id,
+    version,
+    fin,
+    marke,
+    modell,
+    baujahr,
+    erstzulassung,
+    kilometerstand,
+    kraftstoffart,
+    fahrzeugklasse,
+    ausstattung,
+    schadenfrei,
+    beschreibung_url,
+    anbieter_username,
+    kontakt_email,
+    erzeugt,
+    aktualisiert
+)
+FROM '/init/gebrauchtwagen/csv/gebrauchtwagen.csv'
+(FORMAT csv, HEADER true, DELIMITER ';');
+
+COPY standort (
+    id,
+    plz,
+    ort,
+    gebrauchtwagen_id
+)
+FROM '/init/gebrauchtwagen/csv/standort.csv'
+(FORMAT csv, HEADER true, DELIMITER ';');
+
+COPY schaden (
+    id,
+    bezeichnung,
+    beschreibung,
+    feststellungsdatum,
+    gebrauchtwagen_id
+)
+FROM '/init/gebrauchtwagen/csv/schaden.csv'
+(FORMAT csv, HEADER true, DELIMITER ';');
+
+COPY hauptuntersuchung (
+    id,
+    pruefdatum,
+    gueltig_bis,
+    prueforganisation,
+    status,
+    gebrauchtwagen_id
+)
+FROM '/init/gebrauchtwagen/csv/hauptuntersuchung.csv'
+(FORMAT csv, HEADER true, DELIMITER ';');
+
+SELECT setval(
+    pg_get_serial_sequence('gebrauchtwagen.gebrauchtwagen', 'id'),
+    (SELECT max(id) FROM gebrauchtwagen),
+    true
+);
+SELECT setval(
+    pg_get_serial_sequence('standort', 'id'),
+    (SELECT max(id) FROM standort),
+    true
+);
+SELECT setval(
+    pg_get_serial_sequence('schaden', 'id'),
+    (SELECT max(id) FROM schaden),
+    true
+);
+SELECT setval(
+    pg_get_serial_sequence('hauptuntersuchung', 'id'),
+    (SELECT max(id) FROM hauptuntersuchung),
+    true
+);
