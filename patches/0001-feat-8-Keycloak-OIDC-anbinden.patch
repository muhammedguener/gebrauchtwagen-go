+
+    test('unterstützt kombinierte Filter', async () => {
+        const response = await fetch(
+            `${getBaseUrl()}/api/gebrauchtwagen?fahrzeugklasse=MITTELKLASSE&kraftstoffart=ELEKTRO&schadenfrei=true`,
