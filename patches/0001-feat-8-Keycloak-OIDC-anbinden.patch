@@ -0,0 +1,108 @@
+generator client {
+  provider        = "prisma-client"
+  output          = "../src/generated/prisma"
+  previewFeatures = ["nativeDistinct", "relationJoins"]
+  engineType      = "client"
+}
+
+datasource db {
+  provider = "postgresql"
+  schemas  = ["gebrauchtwagen"]
+}
+
+model Gebrauchtwagen {
+  id                Int                @id @default(autoincrement())
+  fin               String             @unique @db.VarChar(17)
+  marke             String             @db.VarChar(100)
+  modell            String             @db.VarChar(100)
+  baujahr           Int
+  kilometerstand    Int
+  kraftstoffart     Kraftstoffart
+  fahrzeugklasse    Fahrzeugklasse
+  erstzulassung     DateTime           @db.Date
+  schadenfrei       Boolean
+  ausstattung       Json
+  beschreibungUrl   String?            @map("beschreibung_url") @db.VarChar(255)
+  anbieterUsername  String?            @map("anbieter_username") @db.VarChar(100)
+  kontaktEmail      String?            @map("kontakt_email") @db.VarChar(255)
+  erzeugt           DateTime           @default(now()) @db.Timestamp(6)
+  aktualisiert      DateTime           @default(now()) @updatedAt @db.Timestamp(6)
+  version           Int
+  hauptuntersuchung Hauptuntersuchung?
+  schaeden          Schaden[]
+  standort          Standort?
+
+  @@map("gebrauchtwagen")
+  @@schema("gebrauchtwagen")
+}
+
+model Hauptuntersuchung {
+  id                Int            @id @default(autoincrement())
+  gebrauchtwagenId  Int            @unique @map("gebrauchtwagen_id")
+  pruefdatum        DateTime       @db.Date
+  gueltigBis        DateTime       @map("gueltig_bis") @db.Date
+  prueforganisation String         @db.VarChar(100)
+  status            HuStatus
+  gebrauchtwagen    Gebrauchtwagen @relation(fields: [gebrauchtwagenId], references: [id], onDelete: Cascade, onUpdate: NoAction)
+
+  @@map("hauptuntersuchung")
+  @@schema("gebrauchtwagen")
+}
+
+model Schaden {
+  id                 Int            @id @default(autoincrement())
