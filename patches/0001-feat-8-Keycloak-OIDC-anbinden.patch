diff --git a/extras/compose/postgres/compose.yml b/extras/compose/postgres/compose.yml
new file mode 100644
index 0000000..d3195a0
--- /dev/null
+++ b/extras/compose/postgres/compose.yml
@@ -0,0 +1,68 @@
+name: gebrauchtwagen
+
+services:
+  app:
+    build:
+      context: ../../..
+      dockerfile: Dockerfile
+    image: gebrauchtwagen-ts:latest
+    container_name: gebrauchtwagen-app
+    depends_on:
+      db:
+        condition: service_healthy
+      keycloak:
+        condition: service_started
+    environment:
+      DATABASE_URL: postgresql://gebrauchtwagen:gebrauchtwagen@db:5432/gebrauchtwagen?schema=gebrauchtwagen
+      KEYCLOAK_AUDIENCE: gebrauchtwagen-app
+      KEYCLOAK_ISSUER: http://localhost:${KEYCLOAK_PORT:-8080}/realms/gebrauchtwagen
+      KEYCLOAK_JWKS_URL: http://keycloak:8080/realms/gebrauchtwagen/protocol/openid-connect/certs
+      NODE_ENV: production
+      PORT: 3000
+    ports:
+      - "${APP_PORT:-3000}:3000"
+    healthcheck:
+      test:
+        [
+          "CMD",
+          "bun",
+          "-e",
+          "const r = await fetch('http://127.0.0.1:3000/health/liveness'); process.exit(r.ok ? 0 : 1)",
+        ]
+      interval: 10s
+      timeout: 5s
+      retries: 5
+      start_period: 10s
+    stop_signal: SIGINT
+
+  keycloak:
+    image: quay.io/keycloak/keycloak:26.6.2
+    container_name: gebrauchtwagen-keycloak
+    environment:
+      KC_BOOTSTRAP_ADMIN_USERNAME: ${KC_BOOTSTRAP_ADMIN_USERNAME:-admin}
+      KC_BOOTSTRAP_ADMIN_PASSWORD: ${KC_BOOTSTRAP_ADMIN_PASSWORD:-admin}
+      KC_HEALTH_ENABLED: "true"
+      KC_METRICS_ENABLED: "true"
+    command: ["start-dev", "--http-port=8080", "--import-realm"]
+    volumes:
+      - ../keycloak/realm-export.json:/opt/keycloak/data/import/realm-export.json:ro
+    ports:
+      - "${KEYCLOAK_PORT:-8080}:8080"
+
+  db:
+    image: postgres:17
+    container_name: gebrauchtwagen-db
+    environment:
+      POSTGRES_DB: gebrauchtwagen
+      POSTGRES_USER: gebrauchtwagen
+      POSTGRES_PASSWORD: gebrauchtwagen
+    volumes:
+      - ./init:/init:ro
+      - ./init:/docker-entrypoint-initdb.d:ro
+    ports:
+      - "5432:5432"
+    healthcheck:
+      test: ["CMD-SHELL", "pg_isready -U gebrauchtwagen -d gebrauchtwagen"]
+      interval: 10s
+      timeout: 5s
+      retries: 5
