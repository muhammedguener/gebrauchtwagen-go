+DATABASE_URL="postgresql://gebrauchtwagen:gebrauchtwagen@localhost:5432/gebrauchtwagen?schema=gebrauchtwagen"
+
+# Optionale Variablen fuer `docker compose -f extras\compose\postgres\compose.yml`
+APP_PORT="3000"
+KEYCLOAK_PORT="8080"
+KC_BOOTSTRAP_ADMIN_USERNAME="admin"
+KC_BOOTSTRAP_ADMIN_PASSWORD="admin"
+
+# Keycloak OIDC-Konfiguration fuer lokale Ausfuehrung ohne Docker
+KEYCLOAK_ISSUER="http://localhost:8080/realms/gebrauchtwagen"
+KEYCLOAK_AUDIENCE="gebrauchtwagen-app"
+KEYCLOAK_JWKS_URL="http://localhost:8080/realms/gebrauchtwagen/protocol/openid-connect/certs"
