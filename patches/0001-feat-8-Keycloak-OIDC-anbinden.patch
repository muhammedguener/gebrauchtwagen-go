+
+    test('liefert Prometheus-Metriken', async () => {
+        await fetch(`${getBaseUrl()}/health/liveness`);
+
+        const response = await fetch(`${getBaseUrl()}/prometheus`);
+        const body = await response.text();
+
+        expect(response.status).toBe(200);
