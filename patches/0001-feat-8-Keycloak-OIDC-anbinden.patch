+        expect(response.status).toBe(200);
+        expect(body.data.length).toBeGreaterThan(0);
+        expect(body.data.every((item) => item.marke === 'VW')).toBe(true);
+        expect(
+            body.data.every((item) =>
+                item.modell.toLowerCase().includes('golf'),
